{
  "name": "helper-30-30",
  "version": "1.0.0",
  "description": "30·30 Helper — every 30 min look out the window, every 60 min stand up and drink water",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win dir"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.yuchen.helper3030",
    "productName": "30-30",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "renderer.js",
      "icon.ico"
    ],
    "win": {
      "target": "dir",
      "icon": "build/icon.ico"
    }
  }
}
